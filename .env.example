# django Settings Configuration
# Copy this file to .env and fill in the actual values

# --- Security ---
SECRET_KEY=django-insecure-generate-a-proper-one-for-production
DEBUG=True
# Comma-separated list of hosts
ALLOWED_HOSTS=127.0.0.1,localhost,sjis.edu.bd,www.sjis.edu.bd

# --- Database ---
# Options: sqlite, postgresql, mysql
DB_ENGINE=sqlite
DB_NAME=db.sqlite3
# For PostgreSQL/MySQL, uncomment and fill:
# DB_USER=db_user
# DB_PASSWORD=db_password
# DB_HOST=localhost
# DB_PORT=5432

# --- Email ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=info@sjis.edu.bd

# --- Environment ---
# Optional: Set to 'production' to enable strict security headers
ENVIRONMENT=local
